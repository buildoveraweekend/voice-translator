# .env.example
# ─────────────────────────────────────────────────────────
# ⚠️  THIS FILE MUST BE IN THE frontend/ FOLDER
# Not in the root of the repo — in frontend/
#
# To create your .env file:
#   Mac/Linux:  cp .env.example frontend/.env
#   Windows:    copy .env.example frontend\.env
#
# Then fill in your values below and restart npm start
# ─────────────────────────────────────────────────────────

# Your API Gateway endpoint (from AWS Console after deploying)
REACT_APP_API_URL=https://YOUR-API-ID.execute-api.eu-west-2.amazonaws.com/prod/translate

# AWS Region (only needed for local testing — Lambda uses its own region)
AWS_DEFAULT_REGION=eu-west-2

# ─────────────────────────────────────────────────────────
# ⚠️  CHANGE THIS — S3 bucket names must be globally unique.
# Replace YOUR-NAME with your own name or something unique.
# Must be lowercase, no spaces, no underscores.
# Example: voice-translator-mukesh-2024
# ────

# Your S3 bucket name (must be globally unique)
BUCKET_NAME=voice-translator-YOUR-NAME-2026